# Copy this file to `.env` and fill in your credentials:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (macOS/Linux)

# --- X (Twitter) ---
# Create an app at https://developer.x.com/ with read+write permissions.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# --- Reddit ---
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=social-poster/1.0 by u/your_username
REDDIT_SUBREDDIT=test
# reddit_outreach.py — comma-separated subs to scan for PIP help threads
REDDIT_SCAN_SUBREDDITS=UKPersonalFinance,Benefits,LegalAdviceUK,unitedkingdom
REDDIT_SCAN_TIME=week
# Minimum hours between posted comments (avoid spam flags)
REDDIT_MIN_HOURS_BETWEEN=4

# --- Anthropic (comment drafts in reddit_outreach.py) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
PIPPAL_SITE_URL=https://www.pippal.uk

# --- TikTok ---
# Register at https://developers.tiktok.com/ and enable Login Kit + Content Posting API.
# Run: python tiktok_auth.py  (one-time) to get tokens after filling CLIENT_KEY/SECRET below.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-site.com/tiktok/callback
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
# Public URL of the image on a TikTok-verified domain (not a local file path).
TIKTOK_PHOTO_PUBLIC_URL=https://your-verified-domain.com/path/to/image.jpg
# MEDIA_UPLOAD = inbox draft (easier for testing). DIRECT_POST = publish immediately.
TIKTOK_POST_MODE=MEDIA_UPLOAD
TIKTOK_PRIVACY_LEVEL=SELF_ONLY

# --- Optional: disable platforms without deleting credentials ---
POST_TO_X=true
POST_TO_REDDIT=true
POST_TO_TIKTOK=true
